            "3-1": {
                title: "Remove Hardcoded Username 'dgarner' from setup.yml",
                problem: "The username 'dgarner' appears 14 times, making the playbook completely non-portable. It will fail on every system where this user doesn't exist.",
                impact: {
                    severity: "Critical - Breaking",
                    affectedFiles: "setup.yml (14 occurrences)",
                    executionImpact: "Fails with 'user dgarner does not exist'",
                    timeToFix: "30 minutes"
                },
                technicalDetails: `
                    <p>Hardcoded occurrences at lines: 488, 557, 575, 592, 596, 600, 604, 608, 612, 620, 622, 626, 632, 644</p>
                    <p><strong>Examples of broken code:</strong></p>
                    <pre>become_user: dgarner  # Line 488 - Fails if user doesn't exist
user: dgarner         # Line 557 - Creates paths for wrong user
path: /home/dgarner   # Line 575 - Hardcoded home directory</pre>
                    <p><strong>Should use:</strong></p>
                    <pre>become_user: "{{ ansible_user_id }}"
user: "{{ ansible_user_id }}"
path: "{{ ansible_env.HOME }}"</pre>
                `,
                metrics: [
                    {label: "Portability Score", current: "0% (1 user only)", after: "100% (any user)"},
                    {label: "Code Reusability", current: "None", after: "Full"},
                    {label: "Setup Time on New System", current: "Manual editing required", after: "Zero config"},
                    {label: "Team Collaboration", current: "Impossible", after: "Seamless"}
                ],
