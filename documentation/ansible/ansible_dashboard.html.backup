        // Sub-item detailed information
        const subItemDetails = {
            "1-1": {
                title: "Fix include_tasks Paths in setup_all.yml",
                problem: "The playbook references task files that don't exist at the specified paths, causing immediate execution failure.",
                impact: {
                    severity: "Critical - Breaking",
                    affectedFiles: 1,
                    executionImpact: "Playbook fails on first include_tasks",
                    timeToFix: "15 minutes"
                },
                technicalDetails: `
